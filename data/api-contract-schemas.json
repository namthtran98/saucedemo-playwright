{
  "health": {
    "type": "object",
    "required": ["status"],
    "additionalProperties": false,
    "properties": {
      "status": { "type": "string", "enum": ["ok"] }
    }
  },
  "product": {
    "type": "object",
    "required": ["id", "title", "price", "category", "description"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "integer" },
      "title": { "type": "string", "minLength": 1 },
      "price": { "type": "number", "minimum": 0 },
      "category": { "type": "string", "minLength": 1 },
      "description": { "type": "string" }
    }
  },
  "createdProduct": {
    "type": "object",
    "required": ["id", "title", "price"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "integer" },
      "title": { "type": "string", "minLength": 1 },
      "price": { "type": "number", "minimum": 0 }
    }
  },
  "productList": {
    "type": "array",
    "items": {
      "type": "object",
      "required": ["id", "title", "price", "category", "description"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string", "minLength": 1 },
        "price": { "type": "number", "minimum": 0 },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string" }
      }
    }
  },
  "categories": {
    "type": "array",
    "items": { "type": "string", "minLength": 1 }
  },
  "user": {
    "type": "object",
    "required": ["id", "name", "email"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "integer" },
      "name": { "type": "string", "minLength": 1 },
      "email": { "type": "string", "minLength": 1 }
    }
  },
  "userList": {
    "type": "array",
    "items": {
      "type": "object",
      "required": ["id", "name", "email"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "minLength": 1 }
      }
    }
  },
  "token": {
    "type": "object",
    "required": ["token"],
    "additionalProperties": false,
    "properties": {
      "token": { "type": "string", "minLength": 1 }
    }
  },
  "post": {
    "type": "object",
    "required": ["id", "title", "body", "userId"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "integer" },
      "title": { "type": "string", "minLength": 1 },
      "body": { "type": "string" },
      "userId": { "type": "integer" }
    }
  },
  "postList": {
    "type": "array",
    "items": {
      "type": "object",
      "required": ["id", "title", "body", "userId"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "integer" },
        "title": { "type": "string", "minLength": 1 },
        "body": { "type": "string" },
        "userId": { "type": "integer" }
      }
    }
  },
  "updatedPost": {
    "type": "object",
    "required": ["id", "title"],
    "additionalProperties": false,
    "properties": {
      "id": { "type": "integer" },
      "title": { "type": "string", "minLength": 1 }
    }
  },
  "emptyObject": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "error": {
    "type": "object",
    "required": ["error"],
    "additionalProperties": false,
    "properties": {
      "error": { "type": "string", "minLength": 1 }
    }
  }
}
