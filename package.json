{
  "name": "playwright-project-pack",
  "version": "1.0.0",
  "private": true,
  "description": "Production-ready Playwright framework with 125 tests (88 UI + 32 API + 2 visual + 3 accessibility).",
  "scripts": {
    "test": "playwright test --project=ui --project=api",
    "test:all": "npm test && npm run test:visual && npm run test:accessibility",
    "test:ui": "playwright test --project=ui",
    "test:api": "playwright test --project=api",
    "test:visual": "playwright test --project=visual",
    "test:accessibility": "playwright test --project=accessibility",
    "generate:api-contract-types": "node scripts/generate-api-contract-types.mjs",
    "test:visual:update": "playwright test --project=visual --update-snapshots",
    "test:visual:update:linux": "docker run --rm -v \"$(pwd):/work\" -w /work mcr.microsoft.com/playwright:v1.60.0-noble npx playwright test --project=visual --update-snapshots",
    "test:headed": "playwright test --headed --workers=1",
    "test:debug": "cross-env PWDEBUG=1 playwright test --workers=1",
    "mock-api": "node mock-api/server.mjs",
    "report": "playwright show-report"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.11.0",
    "ajv": "^8.20.0",
    "cross-env": "^7.0.3",
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.4.0"
  }
}
